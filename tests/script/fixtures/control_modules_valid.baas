import "baas/log" as log;
import "tasks/common" as common;

fn make_counter(seed = 0) {
    let value = seed;
    fn next() { value += 1; return value; }
    return next;
}

fn factorial(n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}

let counter = make_counter();
let first = counter();
let answer = factorial(5);

let total = 0;
for (item in [1, 2, 3]) {
    if (item == 2) { continue; }
    total += item;
}
while (total < 10) {
    total += 1;
    if (total == 9) { break; }
}
if (total > 0) { log.info(total); } else { common.run(); }

let c0 = null;
let c1 = null;
let pc = 0;
let halt = -1;
while (pc != halt) {
    if (pc == 0) {
        c0 = [c0];
        pc = 1;
    } else {
        if (c0 is null) {
            pc = halt;
        } else {
            c0 = c0[0];
            c1 = [c1];
            pc = 0;
        }
    }
}
